{
  "realm": "decider-local",
  "enabled": true,
  "displayName": "Decider Local",
  "registrationAllowed": false,
  "resetPasswordAllowed": false,
  "rememberMe": true,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Decider tenant administrator"
      },
      {
        "name": "analyst",
        "description": "Decider analyst"
      },
      {
        "name": "user",
        "description": "Decider tenant user"
      }
    ]
  },
  "groups": [
    {
      "name": "tenant-acme"
    },
    {
      "name": "tenant-umbrella"
    }
  ],
  "clientScopes": [
    {
      "name": "tenant-claims",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "tenant_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "tenant_id",
            "claim.name": "tenant_id",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "tenant",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "tenant",
            "claim.name": "tenant",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "org_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "org_id",
            "claim.name": "org_id",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "subject",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "username",
            "claim.name": "sub",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "decider-api-audience",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "decider-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "decider-api",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        }
      ]
    },
    {
      "name": "read:data",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "watchlist:view",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "export:data",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "entitlements:write",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    }
  ],
  "clients": [
    {
      "clientId": "decider-api",
      "enabled": true,
      "bearerOnly": true,
      "protocol": "openid-connect"
    },
    {
      "clientId": "decider-frontend",
      "name": "Decider Frontend",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:4200/*"
      ],
      "webOrigins": [
        "http://localhost:4200"
      ],
      "fullScopeAllowed": false,
      "defaultClientScopes": [
        "tenant-claims",
        "decider-api-audience",
        "read:data",
        "watchlist:view",
        "export:data",
        "entitlements:write"
      ],
      "optionalClientScopes": []
    },
    {
      "clientId": "decider-cli",
      "name": "Decider CLI",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": false,
      "defaultClientScopes": [
        "tenant-claims",
        "decider-api-audience",
        "read:data",
        "watchlist:view",
        "export:data",
        "entitlements:write"
      ],
      "optionalClientScopes": []
    }
  ],
  "users": [
    {
      "username": "demo-user",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "User",
      "email": "demo-user@decider.local",
      "attributes": {
        "tenant_id": [
          "acme"
        ],
        "tenant": [
          "acme"
        ],
        "org_id": [
          "acme"
        ]
      },
      "realmRoles": [
        "user"
      ],
      "groups": [
        "/tenant-acme"
      ]
    },
    {
      "username": "demo-admin",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "Admin",
      "email": "demo-admin@decider.local",
      "attributes": {
        "tenant_id": [
          "acme"
        ],
        "tenant": [
          "acme"
        ],
        "org_id": [
          "acme"
        ]
      },
      "realmRoles": [
        "admin"
      ],
      "groups": [
        "/tenant-acme"
      ]
    }
  ]
}
