# Copy this file to .env.runtime and replace all placeholder values.
# Never commit .env.runtime.

DECIDER_KEYCLOAK_ADMIN_USER=<set-local-admin-user>
DECIDER_KEYCLOAK_ADMIN_PASSWORD=<set-local-admin-password>
DECIDER_KEYCLOAK_DEMO_USER_PASSWORD=<set-demo-user-password>
DECIDER_KEYCLOAK_DEMO_ADMIN_PASSWORD=<set-demo-admin-password>
DECIDER_LOCAL_API_PORT=8000
